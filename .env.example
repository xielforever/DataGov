# DataGov local backend environment template.
# Copy to .env.local and fill secrets locally. Do not commit .env.local.

DATAGOV_ENV=development
DATAGOV_LOG_LEVEL=info
VITE_BACKEND_TARGET=http://127.0.0.1:8080
VITE_REAL_METADATA_DATA_SOURCES=true
VITE_REAL_ASSETS=true
VITE_REAL_DEVELOPMENT_SCRIPTS=true
VITE_REAL_AI_ASSISTANT=true
VITE_REAL_APPROVALS=true
VITE_REAL_SYSTEM_MANAGEMENT=true
DATAGOV_API_HOST=127.0.0.1
DATAGOV_API_PORT=8080
DATAGOV_AUTO_MIGRATE=true
DATAGOV_MIGRATIONS_DIR=backend/migrations
DATAGOV_PG_CONNECT_TIMEOUT_SECONDS=5
DATAGOV_AUTH_TOKEN_TTL_HOURS=8
DATAGOV_AUTH_REMEMBER_TTL_HOURS=168
DATAGOV_BOOTSTRAP_ADMIN_USERNAME=admin
DATAGOV_BOOTSTRAP_ADMIN_PASSWORD=replace-with-local-secret
DATAGOV_BOOTSTRAP_ADMIN_REAL_NAME=系统管理员

DATAGOV_PG_HOST=10.40.64.101
DATAGOV_PG_PORT=5432
DATAGOV_PG_DATABASE=datagov
DATAGOV_PG_USER=datagov_app
DATAGOV_PG_PASSWORD=replace-with-local-secret
DATAGOV_DATABASE_URL=postgres://datagov_app:replace-with-local-secret@10.40.64.101:5432/datagov?sslmode=disable

DATAGOV_REDIS_ADDR=10.40.64.101:6379
DATAGOV_REDIS_PASSWORD=
DATAGOV_REDIS_DB=6
DATAGOV_REDIS_KEY_PREFIX=datagov:dev:

DATAGOV_SAMPLE_PG_HOST=10.40.64.101
DATAGOV_SAMPLE_PG_PORT=5432
DATAGOV_SAMPLE_PG_DATABASE=datagov_sample
DATAGOV_SAMPLE_PG_USER=datagov_reader
DATAGOV_SAMPLE_PG_PASSWORD=replace-with-local-secret
DATAGOV_SAMPLE_DATABASE_URL=postgres://datagov_reader:replace-with-local-secret@10.40.64.101:5432/datagov_sample?sslmode=disable

ANTHROPIC_BASE_URL=https://api.minimaxi.com/anthropic
ANTHROPIC_API_KEY=replace-with-local-secret
ANTHROPIC_MODEL=MiniMax-M3
DATAGOV_AI_DAILY_QUOTA_TOKENS=200000
DATAGOV_AI_USER_RATE_LIMIT_PER_MINUTE=20
DATAGOV_AI_GLOBAL_RATE_LIMIT_PER_MINUTE=120
DATAGOV_AI_REDIS_KEY_PREFIX=datagov:dev:ai:

MINIMAX_BASE_URL=https://api.minimaxi.com/anthropic
MINIMAX_API_KEY=replace-with-local-secret
MINIMAX_MODEL=MiniMax-M3
